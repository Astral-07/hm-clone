# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

# If specified, validates that the Maven version is correct
if [ -n "$MVNW_REPOURL" ]; then
  MAVEN_REPOURL="$MVNW_REPOURL"
else
  MAVEN_REPOURL="https://repo.maven.apache.org/maven2"
fi

# OS specific support.
cygwin=false
darwin=false
mingw=false
case "$(uname)" in
  CYGWIN*) cygwin=true ;;
  MINGW*) mingw=true ;;
  Darwin*) darwin=true ;;
esac

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="$(which java)"
  if [ -n "$javaExecutable" ] && ! [ "$(expr "$javaExecutable" : '\([^ ]*\)')" = "no" ]; then
    readLink=$(which readlink)
    if [ -n "$readLink" ]; then
      if $cygwin; then
        javaExecutable=$(cygpath --unix "$javaExecutable")
      fi
      javaExecutable=$(readlink -f "$javaExecutable")
      javaHome=$(dirname "$javaExecutable")
      javaHome=$(expr "$javaHome" : '\(.*\)/bin')
      JAVA_HOME="$javaHome"
      export JAVA_HOME
    fi
  fi
fi

MAVEN_OPTS="$(cat .mvn/jvm.config 2>/dev/null || true)"
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-}"

find_maven_basedir() {
  if [ -z "$1" ]; then
    echo "Path not specified to find_maven_basedir"
    return 1
  fi

  basedir="$1"
  wdir="$1"
  while [ "$wdir" != '/' ]; do
    if [ -d "$wdir"/.mvn ]; then
      basedir=$wdir
      break
    fi
    wdir=$(cd "$wdir/.." && pwd)
  done
  printf '%s' "$(cd "$basedir" && pwd)"
}

if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR=$(find_maven_basedir "$(pwd)")
  export MAVEN_PROJECTBASEDIR
fi

MVNW_VERBOSE=false
if [ -n "$MVNW_VERBOSE" ]; then
  echo $MAVEN_PROJECTBASEDIR
fi

WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
if [ -f "$WRAPPER_PROPERTIES" ]; then
  DOWNLOAD_URL=$(grep "wrapperUrl" "$WRAPPER_PROPERTIES" | cut -d'=' -f2)
fi

if [ -r "$WRAPPER_JAR" ]; then
  if [ "$MVNW_VERBOSE" = true ]; then
    echo "Found $WRAPPER_JAR"
  fi
else
  if [ "$MVNW_VERBOSE" = true ]; then
    echo "Couldn't find $WRAPPER_JAR, downloading it ..."
    echo "Downloading from: $DOWNLOAD_URL"
  fi

  if ! command -v wget > /dev/null && ! command -v curl > /dev/null; then
    echo "Either wget or curl is required to download the Maven wrapper"
    exit 1
  fi

  if command -v wget > /dev/null; then
    wget "$DOWNLOAD_URL" -q -O "$WRAPPER_JAR" || rm -f "$WRAPPER_JAR"
  elif command -v curl > /dev/null; then
    curl -o "$WRAPPER_JAR" "$DOWNLOAD_URL" -s || rm -f "$WRAPPER_JAR"
  fi
fi

exec "$JAVA_HOME/bin/java" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  $WRAPPER_LAUNCHER "$@"
